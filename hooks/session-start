#!/usr/bin/env bash
# SessionStart hook - Initialize claude-mem session and inject context
# Windows-safe: single cold start only, fail closed on port conflict
set -euo pipefail

WORKER_BASE="${CLAUDE_MEM_WORKER_URL:-http://127.0.0.1:37777}"
STATE_DIR="${HOME}/.claude-mem"
SESSION_FILE="${STATE_DIR}/codex-session.json"

mkdir -p "$STATE_DIR"

# 3a. Clean stale session file to prevent cross-session pollution
rm -f "$SESSION_FILE"

# 3b. Port bindability probe (detects ghost socket / EADDRINUSE)
port_is_bindable() {
  node -e "
const net = require('net');
const u = process.argv[1];
const url = new URL(u);
const host = url.hostname || '127.0.0.1';
const port = Number(url.port) || 37777;
const s = net.createServer();
s.once('error', () => process.exit(1));
s.listen(port, host, () => s.close(() => process.exit(0)));
" "$WORKER_BASE" >/dev/null 2>&1
}

# 3c. Ensure Worker is running — single cold start, fail closed
if ! curl -sf --max-time 2 "${WORKER_BASE}/api/readiness" >/dev/null 2>&1; then
  if port_is_bindable; then
    # Port is free — safe to attempt one cold start
    _CACHE="${HOME}/.claude/plugins/cache/thedotmack/claude-mem"
    _PLUGIN_ROOT=""
    if [ -d "$_CACHE" ]; then
      _LATEST=$(ls -1 "$_CACHE" 2>/dev/null | grep '^[0-9]' | sort -V | tail -1)
      [ -n "$_LATEST" ] && _PLUGIN_ROOT="$_CACHE/$_LATEST"
    fi
    if [ -z "$_PLUGIN_ROOT" ]; then
      _MKT="${HOME}/.claude/plugins/marketplaces/thedotmack/plugin"
      [ -d "$_MKT/scripts" ] && _PLUGIN_ROOT="$_MKT"
    fi

    if [ -n "$_PLUGIN_ROOT" ] && [ -f "$_PLUGIN_ROOT/scripts/bun-runner.js" ]; then
      # Upstream chain: smart-install -> worker start
      # Use Node execFileSync timeout to prevent hanging the synchronous hook
      node -e "
        const { execFileSync } = require('child_process');
        const root = process.argv[1];
        try {
          execFileSync('node', [root + '/scripts/smart-install.js'], {
            cwd: root, stdio: 'ignore', timeout: 60000
          });
        } catch {}
        try {
          execFileSync('node', [root + '/scripts/bun-runner.js', root + '/scripts/worker-service.cjs', 'start'], {
            cwd: root, stdio: 'ignore', timeout: 30000
          });
        } catch {}
      " "$_PLUGIN_ROOT" >/dev/null 2>&1 || true
      # Wait for readiness, max 15s
      for _i in $(seq 1 15); do
        sleep 1
        curl -sf --max-time 2 "${WORKER_BASE}/api/readiness" >/dev/null 2>&1 && break
      done
    fi
  else
    # Port not bindable = dangerous state (ghost socket / zombie)
    # Do NOT attempt start, fail closed
    printf '{}\n'
    exit 0
  fi
fi

# Read stdin for hook data (Codex sends JSON with session info)
HOOK_INPUT=""
if [ ! -t 0 ]; then
  HOOK_INPUT=$(cat 2>/dev/null || true)
fi

# Extract project from hook input or fallback to PWD
PROJECT="${PWD}"
if [ -n "$HOOK_INPUT" ]; then
  EXTRACTED=$(echo "$HOOK_INPUT" | node -e "
    let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
      try{const j=JSON.parse(d);console.log(j.cwd||j.project||'')}catch{console.log('')}
    })" 2>/dev/null || true)
  [ -n "$EXTRACTED" ] && PROJECT="$EXTRACTED"
fi

# Generate session ID
SESSION_ID="codex-$(date +%s)-$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' ')"

# 3d. Init session via Worker API (JSON generated by Node, not hand-spliced)
INIT_PAYLOAD=$(node -e "
console.log(JSON.stringify({
  contentSessionId: process.argv[1],
  project: process.argv[2],
  prompt: ''
}));
" "$SESSION_ID" "$PROJECT")

INIT_RESPONSE=$(curl -s -X POST "${WORKER_BASE}/api/sessions/init" \
  -H "Content-Type: application/json" \
  --data "$INIT_PAYLOAD" \
  2>/dev/null || echo '{"error":"worker unreachable"}')

# 3e. Only save session state if init succeeded
if echo "$INIT_RESPONSE" | grep -q '"error"'; then
  # Init failed — no session file, post-tool-use will skip silently
  printf '{}\n'
  exit 0
fi

SESSION_STATE=$(node -e "
console.log(JSON.stringify({
  sessionId: process.argv[1],
  project: process.argv[2]
}));
" "$SESSION_ID" "$PROJECT")

printf '%s\n' "$SESSION_STATE" > "$SESSION_FILE"

# 3f. Get recent context (proper URL encoding)
CONTEXT=$(curl -sf -G "${WORKER_BASE}/api/context/inject" \
  --data-urlencode "projects=$PROJECT" \
  2>/dev/null || echo "")

# Build injection context
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

CONTEXT_ESCAPED=$(escape_for_json "$CONTEXT")
SESSION_INFO="claude-mem session started: ${SESSION_ID}\\nProject: ${PROJECT}"

if [ -n "$CONTEXT" ] && [ "$CONTEXT" != "{}" ] && [ "$CONTEXT" != "null" ]; then
  INJECT="${SESSION_INFO}\\n\\n${CONTEXT_ESCAPED}"
else
  INJECT="${SESSION_INFO}"
fi

# 3g. Output for hook system (only on success path)
printf '{\n  "additional_context": "%s"\n}\n' "$INJECT"

exit 0
